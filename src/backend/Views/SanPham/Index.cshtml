@model List<SanPham>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}
<section class="trang">
    <div class="tieu-de-trang">
        <h2>Quản lý sản phẩm</h2>
        <a class="nut-chinh" asp-action="Them">+ Thêm sản phẩm</a>
    </div>

    <form class="thanh-cong-cu" method="get">
        <input name="tuKhoa" value="@ViewBag.TuKhoa" placeholder="Tìm kiếm tên bánh..." />
        <select name="loai">
            <option value="">Tất cả loại bánh</option>
            <option selected="@(ViewBag.Loai=="Bánh kem")">Bánh kem</option>
            <option selected="@(ViewBag.Loai=="Bánh mì")">Bánh mì</option>
            <option selected="@(ViewBag.Loai=="Bánh ngọt")">Bánh ngọt</option>
        </select>
        <button class="nut-phu" type="submit">Lọc</button>
    </form>

    <div class="khung">
        <table>
            <thead>
                <tr>
                    <th>Mã bánh</th>
                    <th>Tên bánh</th>
                    <th>Loại bánh</th>
                    <th>Giá bán</th>
                    <th>Số lượng</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaBanh</td>
                    <td>@item.TenBanh</td>
                    <td>@item.LoaiBanh</td>
                    <td>@item.GiaBan.ToString("N0")đ</td>
                    <td>@item.SoLuong</td>
                    <td><span class="nhan">@item.TrangThai</span></td>
                    <td>
                        <a class="nut-sua" asp-action="Sua" asp-route-id="@item.Id">Sửa</a>
                        <a class="nut-xoa" asp-action="Xoa" asp-route-id="@item.Id" onclick="return confirm('Xóa sản phẩm này?')">Xóa</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
