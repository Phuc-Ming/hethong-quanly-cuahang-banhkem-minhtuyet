@model List<ChiTietHoaDon>
@{
    ViewData["Title"] = "Chi tiết hóa đơn";
}
<div class="page-head"><h2>Chi tiết hóa đơn @ViewBag.MaHD</h2><button class="btn primary" onclick="window.print()">In hóa đơn</button></div>
<div class="card">
    <table>
        <thead><tr><th>Mã bánh</th><th>Tên bánh</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr><td>@item.MaBanh</td><td>@item.TenBanh</td><td>@item.SoLuong</td><td>@item.DonGia.ToString("N0")đ</td><td>@item.ThanhTien.ToString("N0")đ</td></tr>
        }
        </tbody>
    </table>
</div>
<a class="btn secondary" asp-action="Index">Quay lại</a>
