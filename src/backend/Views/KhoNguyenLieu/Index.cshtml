@model List<NguyenLieu>
@{
    ViewData["Title"] = "Quản lý kho nguyên liệu";
}
<h2 class="page-title">Quản lý kho nguyên liệu</h2>
<form class="quick-add" method="post" asp-action="Them">
    <input name="MaNL" placeholder="Mã NL" />
    <input name="TenNL" placeholder="Tên nguyên liệu" required />
    <input name="DonVi" placeholder="Đơn vị" required />
    <input name="SoLuongTon" type="number" placeholder="Số lượng tồn" required />
    <select name="TrangThai"><option>Đủ hàng</option><option>Sắp hết</option></select>
    <button class="btn primary">+ Nhập nguyên liệu</button>
</form>
<div class="card"><table><thead><tr><th>Mã nguyên liệu</th><th>Tên nguyên liệu</th><th>Đơn vị</th><th>Số lượng tồn</th><th>Trạng thái</th></tr></thead><tbody>
@foreach (var item in Model)
{
<tr><td>@item.MaNL</td><td>@item.TenNL</td><td>@item.DonVi</td><td>@item.SoLuongTon</td><td><span class="badge">@item.TrangThai</span></td></tr>
}
</tbody></table></div>
