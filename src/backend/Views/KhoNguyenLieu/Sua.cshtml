@model NguyenLieu

@{
    ViewData["Title"] = "Sửa nguyên liệu";
}

<h2 class="page-title">Sửa thông tin nguyên liệu</h2>

@if (TempData["Loi"] != null)
{
    <div class="thong-bao-loi">
        @TempData["Loi"]
    </div>
}

<div class="card form-card">
    <form method="post" asp-action="Sua">
        <label>Mã nguyên liệu</label>
        <input asp-for="MaNL" readonly />

        <label>Tên nguyên liệu</label>
        <input asp-for="TenNL" placeholder="Nhập tên nguyên liệu" required />

        <label>Đơn vị</label>
        <input asp-for="DonVi" placeholder="Nhập đơn vị" required />

        <label>Số lượng tồn</label>
        <input asp-for="SoLuongTon"
               type="text"
               inputmode="numeric"
               placeholder="Nhập số lượng tồn"
               required />

        <label>Trạng thái</label>
        <select asp-for="TrangThai">
            <option value="Đủ hàng">Đủ hàng</option>
            <option value="Sắp hết">Sắp hết</option>
        </select>

        <div class="actions">
            <button type="submit" class="btn primary">Lưu thay đổi</button>
            <a class="btn secondary" asp-action="Index">Hủy</a>
        </div>
    </form>
</div>