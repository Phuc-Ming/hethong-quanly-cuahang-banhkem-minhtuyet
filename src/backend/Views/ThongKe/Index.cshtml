@model BaoCaoThongKe
@{
    ViewData["Title"] = "Thống kê doanh thu";
    var lonNhat = Model.DoanhThuTuan.Count > 0 ? Model.DoanhThuTuan.Max() : 0;
    if (lonNhat == 0) lonNhat = 1;
}
<section class="trang">
    <h2>Thống kê doanh thu</h2>

    <div class="the-thong-ke">
        <div class="the"><span>Tổng doanh thu</span><h3>@Model.TongDoanhThu.ToString("N0")đ</h3></div>
        <div class="the"><span>Số đơn hàng</span><h3>@Model.SoDonHang</h3></div>
        <div class="the"><span>Sản phẩm bán chạy</span><h3>@Model.SanPhamBanChay</h3></div>
        <div class="the"><span>Khách hàng mới</span><h3>@Model.KhachHangMoi</h3></div>
    </div>

    <div class="khung">
        <h3>Biểu đồ doanh thu 5 ngày gần nhất</h3>
        <div class="bieu-do">
            @for (var i = 0; i < Model.DoanhThuTuan.Count; i++)
            {
                var cao = 40 + (double)(Model.DoanhThuTuan[i] / lonNhat) * 220;
                <div class="cot-bieu-do">
                    <div class="cot" style="height:@cao.ToString("0")px" title="@Model.DoanhThuTuan[i].ToString("N0")đ"></div>
                    <div class="nhan-cot">N@(i + 1)</div>
                </div>
            }
        </div>
    </div>
</section>
