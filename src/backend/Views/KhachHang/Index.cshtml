@model List<KhachHang>
@{
    ViewData["Title"] = "Quản lý khách hàng";
}
<section class="trang">
    <div class="tieu-de-trang">
        <h2>Quản lý khách hàng</h2>
        <a class="nut-chinh" asp-action="Them">+ Thêm khách hàng</a>
    </div>

    <form class="thanh-cong-cu" method="get">
        <input name="tuKhoa" value="@ViewBag.TuKhoa" placeholder="Tìm kiếm tên hoặc số điện thoại..." />
        <button class="nut-phu" type="submit">Tìm kiếm</button>
    </form>

    <div class="khung">
        <table>
            <thead>
                <tr>
                    <th>Mã KH</th>
                    <th>Họ tên</th>
                    <th>SĐT</th>
                    <th>Địa chỉ</th>
                    <th>Tổng đơn</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.MaKH</td>
                    <td>@item.HoTen</td>
                    <td>@item.SDT</td>
                    <td>@item.DiaChi</td>
                    <td>@item.TongDon</td>
                    <td>
                        <a class="nut-sua" asp-action="Sua" asp-route-id="@item.Id">Sửa</a>
                        <a class="nut-xoa" asp-action="Xoa" asp-route-id="@item.Id" onclick="return confirm('Xóa khách hàng này?')">Xóa</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
