@model TrangChuViewModel
@{
    ViewData["Title"] = "Trang chủ";
}
<h2 class="page-title">Tổng quan hệ thống</h2>
<div class="stats-grid">
    <div class="stat"><span>Doanh thu hôm nay</span><strong>@Model.DoanhThuHomNay.ToString("N0")đ</strong></div>
    <div class="stat"><span>Hóa đơn hôm nay</span><strong>@Model.HoaDonHomNay</strong></div>
    <div class="stat"><span>Sản phẩm đang bán</span><strong>@Model.SanPhamDangBan</strong></div>
    <div class="stat"><span>Nguyên liệu sắp hết</span><strong>@Model.NguyenLieuSapHet</strong></div>
</div>
<div class="card">
    <h3>Hóa đơn gần đây</h3>
    <table>
        <thead><tr><th>Mã HĐ</th><th>Khách hàng</th><th>Ngày lập</th><th>Tổng tiền</th><th>Trạng thái</th></tr></thead>
        <tbody>
        @foreach (var item in Model.HoaDonGanDay)
        {
            <tr>
                <td>@item.MaHD</td>
                <td>@item.HoTenKhachHang</td>
                <td>@item.NgayLap.ToString("dd/MM/yyyy")</td>
                <td>@item.TongTien.ToString("N0")đ</td>
                <td><span class="badge">@item.TrangThai</span></td>
            </tr>
        }
        </tbody>
    </table>
</div>
