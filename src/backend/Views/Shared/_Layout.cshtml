@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var hoTen = Context.Session.GetString("HoTen") ?? "";
    bool dangNhap = !string.IsNullOrEmpty(hoTen);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Minh Tuyết Bakery</title>
    <link rel="stylesheet" href="~/css/giao-dien.css" asp-append-version="true" />
</head>
<body>
@if (dangNhap)
{
    <div class="layout">
        <aside class="sidebar">
            <div class="brand">
                <div class="logo">🎂</div>
                <div><strong>Minh Tuyết</strong><span>Bakery Manager</span></div>
            </div>
            <nav>
                <a class="@(controller=="TrangChu" ? "active" : "")" asp-controller="TrangChu" asp-action="Index">Trang chủ</a>
                <a class="@(controller=="SanPham" ? "active" : "")" asp-controller="SanPham" asp-action="Index">Sản phẩm</a>
                <a class="@(controller=="HoaDon" && action!="Tao" ? "active" : "")" asp-controller="HoaDon" asp-action="Index">Hóa đơn</a>
                <a class="@(controller=="HoaDon" && action=="Tao" ? "active" : "")" asp-controller="HoaDon" asp-action="Tao">Tạo hóa đơn</a>
                <a class="@(controller=="KhachHang" ? "active" : "")" asp-controller="KhachHang" asp-action="Index">Khách hàng</a>
                <a class="@(controller=="KhoNguyenLieu" ? "active" : "")" asp-controller="KhoNguyenLieu" asp-action="Index">Kho nguyên liệu</a>
                <a class="@(controller=="ThongKe" ? "active" : "")" asp-controller="ThongKe" asp-action="Index">Thống kê</a>
                <a class="@(controller=="NhanVien" ? "active" : "")" asp-controller="NhanVien" asp-action="Index">Nhân viên</a>
                <a class="logout" asp-controller="DangNhap" asp-action="DangXuat">Đăng xuất</a>
            </nav>
        </aside>
        <main class="content">
            <header class="topbar">
                <div>
                    <h1>Hệ thống quản lý cửa hàng bánh kem Minh Tuyết</h1>
                    <p>Quản lý sản phẩm, hóa đơn, khách hàng, kho và doanh thu</p>
                </div>
                <div class="hello">Xin chào, <strong>@hoTen</strong></div>
            </header>
            @RenderBody()
        </main>
    </div>
}
else
{
    @RenderBody()
}
<script src="~/js/xu-ly.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
