@{
    ViewData["Title"] = "Đăng nhập";
}
<div class="login-page">
    <section class="login-left">
        <h1>Minh Tuyết Bakery</h1>
        <p>Quản lý sản phẩm, hóa đơn, khách hàng và doanh thu dễ dàng hơn.</p>
        <div class="cake-gallery">
            <img src="~/images/banh1.jpg" alt="Bánh kem dâu" />
            <img src="~/images/banh2.jpg" alt="Bánh socola" />
            <img src="~/images/banh3.jpg" alt="Bánh tiramisu" />
            <img src="~/images/banh4.jpg" alt="Bánh sinh nhật" />
        </div>
    </section>
    <section class="login-card">
        <h2>Đăng nhập hệ thống</h2>
        @if (ViewBag.Loi != null)
        {
            <div class="alert">@ViewBag.Loi</div>
        }
        <form method="post">
            <label>Tên đăng nhập</label>
            <input name="taiKhoan" autocomplete="username" required />
            <label>Mật khẩu</label>
            <input name="matKhau" type="password" autocomplete="current-password" required />
            <button class="btn primary" type="submit">Đăng nhập</button>
        </form>
        <small>© 2026 Cửa hàng bánh kem Minh Tuyết</small>
    </section>
</div>
