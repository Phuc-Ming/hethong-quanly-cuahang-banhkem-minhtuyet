@{
    ViewData["Title"] = "Đăng nhập";
}
<div class="trang-dang-nhap">
    <div class="ben-trai">
        <h1>Minh Tuyết Bakery</h1>
        <p>Quản lý sản phẩm, đơn hàng, hóa đơn và doanh thu dễ dàng hơn.</p>
        <div class="bieu-tuong-banh">🎂</div>
    </div>

    <div class="ben-phai">
        <form class="hop-dang-nhap" method="post">
            <h2>Đăng nhập hệ thống</h2>

            @if (ViewBag.Loi != null)
            {
                <div class="thong-bao-loi">@ViewBag.Loi</div>
            }

            <label>Tên đăng nhập</label>
            <input name="taiKhoan" placeholder="Nhập tên đăng nhập" />

            <label>Mật khẩu</label>
            <input name="matKhau" type="password" placeholder="Nhập mật khẩu" />

            <button type="submit">Đăng nhập</button>

            <p class="ghi-chu">Tài khoản demo: <b>admin</b> / <b>123456</b></p>
            <p class="ban-quyen">© 2026 Cửa hàng bánh kem Minh Tuyết</p>
        </form>
    </div>
</div>
